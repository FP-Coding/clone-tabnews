{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Implementação para praticar e aprender os conteúdos do curso.dev",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run services:wait:database && npm run migrations:up && next dev",
    "test": "npm run services:up && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand\"",
    "posttest": "npm run services:stop",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "build": "next build",
    "start": "next start",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:wait:database": "node infra/scripts/waitForPostgres.js",
    "migrations:create": "node-pg-migrate --migrations-dir infra/migrations create",
    "migrations:up": "node-pg-migrate --migrations-dir infra/migrations --envPath .env.development up",
    "lint:eslint:check": "npx eslint .",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "prepare": "husky",
    "commit": "cz",
    "request:get:status:staging": "curl -s https://clone-tabnews-fpds-git-fix-migrations-11c265-fpcodings-projects.vercel.app/api/v1/status | jq",
    "request:get:status:production": "curl -s https://clone-tabnews-gtxs.vercel.app/api/v1/status | jq",
    "request:get:status:staging:watch": "watch -n 1 'curl -s https://clone-tabnews-fpds-git-fix-migrations-11c265-fpcodings-projects.vercel.app/api/v1/status | jq' ",
    "request:get:status:production:watch": "watch -n 1 'curl -s https://clone-tabnews-gtxs.vercel.app/api/v1/status | jq' ",
    "request:get:migrations:staging": "curl -s https://clone-tabnews-fpds-git-fix-migrations-11c265-fpcodings-projects.vercel.app/api/v1/migrations | jq",
    "request:get:migrations:production": "curl -s https://clone-tabnews-gtxs.vercel.app/api/v1/migrations | jq",
    "request:post:migrations:staging": "curl -s -X POST https://clone-tabnews-fpds-git-fix-migrations-11c265-fpcodings-projects.vercel.app/api/v1/migrations | jq",
    "request:post:migrations:production": "curl -s -X POST https://clone-tabnews-gtxs.vercel.app/api/v1/migrations | jq"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "async-retry": "1.3.3",
    "dotenv": "16.4.4",
    "dotenv-expand": "11.0.6",
    "next": "13.1.6",
    "node-pg-migrate": "6.2.2",
    "pg": "8.11.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.2.2",
    "commitizen": "4.3.0",
    "concurrently": "8.2.2",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jest": "28.6.0",
    "husky": "9.1.4",
    "jest": "29.6.2",
    "prettier": "2.8.8"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
