{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Implementação para praticar e aprender os conteúdos do curso.dev",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run wait-for-postgres && npm run migration:up && next dev",
    "build": "next build",
    "start": "next start",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "lint:eslint:check": "next lint --dir .",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "test": "npm run services:up && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand\"",
    "test:watch": "jest --watchAll --runInBand",
    "migration:create": "node-pg-migrate --migrations-dir infra/migrations create",
    "migration:up": "node-pg-migrate --migrations-dir infra/migrations --envPath .env.development up",
    "status:get:production": "curl -s https://clone-tabnews-gtxs.vercel.app/api/v1/status | jq",
    "status:get:production:watch": "watch -n 1 'curl -s https://clone-tabnews-gtxs.vercel.app/api/v1/status | jq' ",
    "migration:get:production": "curl -s https://clone-tabnews-gtxs.vercel.app/api/v1/migrations | jq",
    "migration:post:production": "curl -s -X POST https://clone-tabnews-gtxs.vercel.app/api/v1/migrations | jq",
    "status:get:staging": "curl -s https://clone-tabnews-fpds-git-fix-migrations-11c265-fpcodings-projects.vercel.app/api/v1/status | jq",
    "status:get:staging:watch": "watch -n 1 'curl -s https://clone-tabnews-fpds-git-fix-migrations-11c265-fpcodings-projects.vercel.app/api/v1/status | jq' ",
    "migration:get:staging": "curl -s https://clone-tabnews-fpds-git-fix-migrations-11c265-fpcodings-projects.vercel.app/api/v1/migrations | jq",
    "migration:post:staging": "curl -s -X POST https://clone-tabnews-fpds-git-fix-migrations-11c265-fpcodings-projects.vercel.app/api/v1/migrations | jq",
    "wait-for-postgres": "node infra/scripts/waitForPostgres.js",
    "prepare": "husky",
    "commit": "cz"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@commitlint/config-conventional": "^19.2.2",
    "async-retry": "^1.3.3",
    "commitizen": "^4.3.0",
    "dotenv": "^16.4.4",
    "dotenv-expand": "^11.0.6",
    "next": "^13.1.6",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "concurrently": "^8.2.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.6.0",
    "husky": "^9.1.4",
    "jest": "^29.6.2",
    "prettier": "^3.8.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
